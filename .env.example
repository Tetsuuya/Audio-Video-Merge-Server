# DUBBING MERGE SERVER - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values

# Server Configuration
PORT=8080
NODE_ENV=development

# Authentication
# Generate with: openssl rand -base64 32
# Must match the secret configured in Next.js app on Vercel
CUSTOM_DUBBING_SECRET=your-secret-here

# Server URL (for generating download URLs)
# Local: http://localhost:8080
# Production: https://your-server.railway.app
SERVER_URL=http://localhost:8080

# Cleanup Configuration
# Delete files older than X hours (default: 24)
CLEANUP_MAX_AGE_HOURS=24
# Run cleanup every X hours (default: 1)
CLEANUP_INTERVAL_HOURS=1
# Enable/disable automatic cleanup (default: true)
AUTO_CLEANUP=true

# Storage Configuration (Step 4 - to be decided)
# Option A: Local disk (default for testing)
# Option B: Free tier cloud storage
# Option C: Cloudflare R2 (requires additional config)
STORAGE_TYPE=local

# R2 Configuration (if using Cloudflare R2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# Replicate API Configuration (for TTS - Kokoro model)
# Get from: https://replicate.com/account/api-tokens
# Model: alphanumericuser/kokoro-82m (better version)
# Default voice: af_heart (Grade A - highest quality)
REPLICATE_API_TOKEN=your-replicate-token-here
KOKORO_MODEL=alphanumericuser/kokoro-82m
KOKORO_DEFAULT_VOICE=af_heart

# AssemblyAI Configuration (for transcription)
# Get from: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# DeepL API (for translation)
# Get from: https://www.deepl.com/pro-api
# Free tier: 1,000,000 characters/month
DEEPL_API_KEY=your-deepl-key-here

# Firebase (for job queue and status tracking)
# For local: Use firebase-credentials.json file (leave this empty)
# For production: Copy entire firebase-credentials.json as single line string
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
FIREBASE_CREDENTIALS=

